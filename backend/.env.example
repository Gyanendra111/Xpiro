# Database
DATABASE_URL=sqlite:///./xpiro.db

# JWT
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SMTP settings for email reminders and contact form
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
EMAIL_FROM=Xpiro Alerts <your-email@example.com>

# Address that receives contact-form submissions (falls back to SMTP_USER)
CONTACT_EMAIL=support@example.com

# Frontend origin for CORS (comma-separated list)
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
